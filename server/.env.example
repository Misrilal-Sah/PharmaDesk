# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL used in password reset emails
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins
# Example production value: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database Configuration
# Option A: individual DB_* variables
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=pharmadesk

# Option B: single URL (takes precedence over DB_* when set)
# DATABASE_URL=mysql://user:password@host:port/database?ssl-mode=REQUIRED

# SSL/TLS for managed MySQL services like Aiven
# Use REQUIRED for Aiven, DISABLED for local mysql
DB_SSL_MODE=DISABLED
# Set false when provider chain is not in system trust store.
# Set true when DB_CA_CERT / DB_CA_PATH is configured.
DB_SSL_REJECT_UNAUTHORIZED=false
# Optional CA certificate (choose one method)
# DB_CA_PATH=./db/ca.pem
# DB_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# DB_CA_BASE64=BASE64_ENCODED_CERT

# JWT Secret (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=PharmaDesk <your_email@gmail.com>

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
